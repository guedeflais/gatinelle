// Schéma de données de l'application Gâtinelle
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  PARTICULIER
  COMMERCANT
}

enum StaffRole {
  AGENT
  ADMIN
}

enum LotStatus {
  ACTIVE
  EXPIRED
  CONVERTED
}

enum TransactionType {
  PURCHASE
  PAYMENT
  CONVERSION
  EXPIRY
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum TransactionStatus {
  PENDING
  COMPLETED
  REJECTED
}

// Liste fermée plutôt que texte libre : évite les variantes de casse/
// orthographe/doublons qui rendraient l'annuaire inutilisable pour
// filtrer les commerçants (voir src/lib/merchantCategory.ts pour les
// libellés en français).
enum MerchantCategory {
  ALIMENTATION
  BOULANGERIE_PATISSERIE
  RESTAURANT_CAFE_BAR
  PRODUCTEUR_MARCHE
  ARTISANAT
  COMMERCE_BOUTIQUE
  BATIMENT_HABITAT
  SANTE_BIEN_ETRE
  BEAUTE_COIFFURE
  CULTURE_LOISIRS
  TOURISME_HEBERGEMENT
  SPORT
  SERVICES_PERSONNE
  SERVICES_PROFESSIONNELS
  TRANSPORT_MOBILITE
  EDUCATION_FORMATION
  AUTRE
}

model User {
  id                String      @id @default(cuid())
  email             String      @unique
  passwordHash      String
  fullName          String
  accountType       AccountType
  staffRole         StaffRole?
  createdAt         DateTime    @default(now())

  // Connexion rapide en caisse : numéro d'adhérent (1 lettre + 5 chiffres) +
  // code PIN à 4 chiffres, sur le modèle de l'Eusko (Euskal Moneta). Bloqué
  // après 3 échecs — déblocage par un administrateur, voir lib/pin.ts.
  memberNumber      String      @unique
  pinHash           String
  pinFailedAttempts Int         @default(0)
  pinBlocked        Boolean     @default(false)

  // Connexion email + mot de passe : pas de blocage permanent (l'email est
  // trop facile à connaître, un blocage définitif serait un vecteur de déni
  // de service contre n'importe quel adhérent) — une pause temporaire
  // auto-expirante après plusieurs échecs, voir lib/auth.ts.
  passwordFailedAttempts Int      @default(0)
  passwordLockedUntil    DateTime?

  wallet          Wallet?
  merchantProfile MerchantProfile?

  validatedMerchants   MerchantProfile[] @relation("MerchantValidatedBy")
  validatedTransactions Transaction[]    @relation("TransactionValidatedBy")
  sentTransactions     Transaction[]     @relation("TransactionFrom")
  receivedTransactions Transaction[]     @relation("TransactionTo")
  mobileSessions       MobileSession[]
  nfcTags              NfcTag[]
}

// Bracelet/carte NFC lié pour le mode festival : numéro de série d'usine du
// tag, utilisé comme seule preuve d'autorisation pour les petits paiements
// au stand (voir payMerchantByWristband dans lib/wallet.ts). Un compte peut
// posséder plusieurs tags (bracelet perdu et réémis, plusieurs porteurs sur
// un même compte, etc.) — d'où une table séparée plutôt qu'un champ sur User.
model NfcTag {
  id        String   @id @default(cuid())
  tagUid    String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

// Jeton d'authentification pour l'application mobile (React Native), qui n'a
// pas de cookie de session partagé avec le site web. Émis par
// POST /api/mobile/login après vérification du numéro d'adhérent+PIN ou de
// l'email+mot de passe (voir lib/pin.ts / lib/passwordAuth.ts, réutilisés à
// l'identique — même verrouillage anti-brute-force que sur le web). Le jeton
// lui-même n'est jamais stocké : seul son empreinte SHA-256 l'est, comme un
// mot de passe, pour qu'une fuite de la base ne suffise pas à usurper une
// session (voir lib/mobileAuth.ts).
model MobileSession {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  tokenHash  String   @unique
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  lastUsedAt DateTime @default(now())

  @@index([userId])
}

model MerchantProfile {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  businessName  String
  address       String
  // Géocodées côté serveur à partir de `address` (voir src/lib/geocoding.ts) ;
  // null si l'adresse n'a pas pu être géolocalisée.
  latitude      Float?
  longitude     Float?
  category      MerchantCategory
  iban          String?
  merchantCode  String    @unique
  validated     Boolean   @default(false)
  // Stand créé pour un événement (voir /api/admin/stands) plutôt qu'un
  // commerçant permanent — permet de le retrouver même après modification
  // de ses autres informations (adresse, catégorie...).
  isEventStand  Boolean   @default(false)
  validatedById String?
  validatedBy   User?     @relation("MerchantValidatedBy", fields: [validatedById], references: [id])
  validatedAt   DateTime?
  createdAt     DateTime  @default(now())

  standProducts StandProduct[]
}

// Catalogue de produits d'un stand (mode festival) : permet d'encaisser en un
// clic (voir StandPaymentForm) plutôt que de taper un montant à la main.
model StandProduct {
  id                String          @id @default(cuid())
  merchantProfileId String
  merchantProfile   MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)
  name              String
  priceCents        Int
  createdAt         DateTime        @default(now())

  @@index([merchantProfileId])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  lots GatinelleLot[]
}

// Montants exprimés en centimes de gâtinelle (Int) pour éviter les erreurs
// d'arrondi liées aux nombres flottants — 1 gâtinelle = 100.
model GatinelleLot {
  id                  String    @id @default(cuid())
  walletId            String
  wallet              Wallet    @relation(fields: [walletId], references: [id])
  amountCents         Int
  remainingCents      Int
  acquiredAt          DateTime  @default(now())
  // Non nul uniquement pour les lots détenus par un portefeuille PARTICULIER.
  // Les lots détenus par un COMMERCANT ont toujours expiresAt = null (pas de péremption).
  expiresAt           DateTime?
  status              LotStatus @default(ACTIVE)
  sourceTransactionId String?

  @@index([walletId, status])
  @@index([expiresAt])
}

model Transaction {
  id                    String             @id @default(cuid())
  type                  TransactionType
  fromUserId            String?
  fromUser              User?              @relation("TransactionFrom", fields: [fromUserId], references: [id])
  toUserId              String?
  toUser                User?              @relation("TransactionTo", fields: [toUserId], references: [id])
  amountCents           Int
  paymentMethod         PaymentMethod?
  status                TransactionStatus  @default(PENDING)
  validatedById         String?
  validatedBy           User?              @relation("TransactionValidatedBy", fields: [validatedById], references: [id])
  validatedAt           DateTime?
  providerReference     String?            @unique
  createdAt             DateTime           @default(now())

  @@index([type, status])
}
