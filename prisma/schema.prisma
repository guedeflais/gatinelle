// Schéma de données de l'application Gâtinelle
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  PARTICULIER
  COMMERCANT
}

enum StaffRole {
  AGENT
  ADMIN
}

enum LotStatus {
  ACTIVE
  EXPIRED
  CONVERTED
}

enum TransactionType {
  PURCHASE
  PAYMENT
  CONVERSION
  EXPIRY
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum TransactionStatus {
  PENDING
  COMPLETED
  REJECTED
}

// Liste fermée plutôt que texte libre : évite les variantes de casse/
// orthographe/doublons qui rendraient l'annuaire inutilisable pour
// filtrer les commerçants (voir src/lib/merchantCategory.ts pour les
// libellés en français).
enum MerchantCategory {
  ALIMENTATION
  BOULANGERIE_PATISSERIE
  RESTAURANT_CAFE_BAR
  PRODUCTEUR_MARCHE
  ARTISANAT
  COMMERCE_BOUTIQUE
  BATIMENT_HABITAT
  SANTE_BIEN_ETRE
  BEAUTE_COIFFURE
  CULTURE_LOISIRS
  TOURISME_HEBERGEMENT
  SPORT
  SERVICES_PERSONNE
  SERVICES_PROFESSIONNELS
  TRANSPORT_MOBILITE
  EDUCATION_FORMATION
  AUTRE
}

// Cycle de vie d'une Gâtine Box (carte cadeau NFC), voir modèle GatineBox.
enum GatineBoxStatus {
  MANUFACTURED
  SOLD
  ACTIVATED
}

model User {
  id                String      @id @default(cuid())
  email             String      @unique
  passwordHash      String
  fullName          String
  accountType       AccountType
  staffRole         StaffRole?
  createdAt         DateTime    @default(now())

  // Connexion rapide en caisse : numéro d'adhérent (1 lettre + 5 chiffres) +
  // code PIN à 4 chiffres, sur le modèle de l'Eusko (Euskal Moneta). Bloqué
  // après 3 échecs — déblocage par un administrateur, voir lib/pin.ts.
  memberNumber      String      @unique
  pinHash           String
  pinFailedAttempts Int         @default(0)
  pinBlocked        Boolean     @default(false)

  // Connexion email + mot de passe : pas de blocage permanent (l'email est
  // trop facile à connaître, un blocage définitif serait un vecteur de déni
  // de service contre n'importe quel adhérent) — une pause temporaire
  // auto-expirante après plusieurs échecs, voir lib/auth.ts.
  passwordFailedAttempts Int      @default(0)
  passwordLockedUntil    DateTime?

  wallet          Wallet?
  merchantProfile MerchantProfile?

  validatedMerchants   MerchantProfile[] @relation("MerchantValidatedBy")
  validatedTransactions Transaction[]    @relation("TransactionValidatedBy")
  sentTransactions     Transaction[]     @relation("TransactionFrom")
  receivedTransactions Transaction[]     @relation("TransactionTo")
  mobileSessions       MobileSession[]
  nfcTags              NfcTag[]

  manufacturedGatineBoxes GatineBox[] @relation("GatineBoxManufacturedBy")
  activatedGatineBoxes    GatineBox[] @relation("GatineBoxActivatedBy")
}

// Carte/bracelet NFC lié à un compte — utilisé aujourd'hui uniquement par
// l'activation d'une Gâtine Box (voir modèle GatineBox). Un compte peut
// posséder plusieurs tags (carte Gâtine Box ajoutée à un compte déjà
// existant, etc.), d'où une table séparée plutôt qu'un champ sur User. Même
// structure que le modèle NfcTag de la branche dev (mode festival), pour ne
// jamais entrer en conflit de schéma le jour où ce mode sera fusionné dans main.
model NfcTag {
  id        String   @id @default(cuid())
  tagUid    String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

// Jeton d'authentification pour l'application mobile (React Native), qui n'a
// pas de cookie de session partagé avec le site web. Émis par
// POST /api/mobile/login après vérification du numéro d'adhérent+PIN ou de
// l'email+mot de passe (voir lib/pin.ts / lib/passwordAuth.ts, réutilisés à
// l'identique — même verrouillage anti-brute-force que sur le web). Le jeton
// lui-même n'est jamais stocké : seul son empreinte SHA-256 l'est, comme un
// mot de passe, pour qu'une fuite de la base ne suffise pas à usurper une
// session (voir lib/mobileAuth.ts).
model MobileSession {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  tokenHash  String   @unique
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  lastUsedAt DateTime @default(now())

  @@index([userId])
}

model MerchantProfile {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  businessName  String
  address       String
  // Géocodées côté serveur à partir de `address` (voir src/lib/geocoding.ts) ;
  // null si l'adresse n'a pas pu être géolocalisée.
  latitude      Float?
  longitude     Float?
  category      MerchantCategory
  iban          String?
  merchantCode  String    @unique
  validated     Boolean   @default(false)
  validatedById String?
  validatedBy   User?     @relation("MerchantValidatedBy", fields: [validatedById], references: [id])
  validatedAt   DateTime?
  createdAt     DateTime  @default(now())

  soldGatineBoxes GatineBox[]
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  lots GatinelleLot[]
}

// Montants exprimés en centimes de gâtinelle (Int) pour éviter les erreurs
// d'arrondi liées aux nombres flottants — 1 gâtinelle = 100.
model GatinelleLot {
  id                  String    @id @default(cuid())
  walletId            String
  wallet              Wallet    @relation(fields: [walletId], references: [id])
  amountCents         Int
  remainingCents      Int
  acquiredAt          DateTime  @default(now())
  // Non nul uniquement pour les lots détenus par un portefeuille PARTICULIER.
  // Les lots détenus par un COMMERCANT ont toujours expiresAt = null (pas de péremption).
  expiresAt           DateTime?
  status              LotStatus @default(ACTIVE)
  sourceTransactionId String?

  @@index([walletId, status])
  @@index([expiresAt])
}

model Transaction {
  id                    String             @id @default(cuid())
  type                  TransactionType
  fromUserId            String?
  fromUser              User?              @relation("TransactionFrom", fields: [fromUserId], references: [id])
  toUserId              String?
  toUser                User?              @relation("TransactionTo", fields: [toUserId], references: [id])
  amountCents           Int
  paymentMethod         PaymentMethod?
  status                TransactionStatus  @default(PENDING)
  validatedById         String?
  validatedBy           User?              @relation("TransactionValidatedBy", fields: [validatedById], references: [id])
  validatedAt           DateTime?
  providerReference     String?            @unique
  createdAt             DateTime           @default(now())

  @@index([type, status])
}

// Carte cadeau NFC vendue chez n'importe quel commerçant agréé (pas
// seulement en mode festival) — voir cahier des charges section 5.8/7.9.
// Le numéro de box est public (imprimé à l'extérieur de l'emballage, sert à
// la vente et à l'activation) ; seul le hash du code d'activation (imprimé
// sur un papier scellé à l'intérieur) est stocké, jamais le code en clair —
// même principe que pinHash (voir lib/pin.ts). Le prix n'est enregistré
// qu'une seule fois, à la vente, et n'est plus jamais modifiable ensuite.
model GatineBox {
  id                 String          @id @default(cuid())
  boxNumber          String          @unique
  nfcTagUid          String          @unique
  activationCodeHash String

  // Même mécanique de verrouillage que le PIN (voir lib/pin.ts), mais portée
  // par la box elle-même plutôt que par un compte : n'importe qui possédant
  // physiquement la box peut tenter l'activation, pas seulement son titulaire.
  activationFailedAttempts Int     @default(0)
  activationBlocked        Boolean @default(false)

  status GatineBoxStatus @default(MANUFACTURED)

  manufacturedById String
  manufacturedBy   User   @relation("GatineBoxManufacturedBy", fields: [manufacturedById], references: [id])
  createdAt        DateTime @default(now())

  // Renseignés une seule fois, à la vente — jamais modifiés ensuite.
  priceCents              Int?
  soldByMerchantProfileId String?
  soldByMerchantProfile   MerchantProfile? @relation(fields: [soldByMerchantProfileId], references: [id])
  soldAt                  DateTime?

  // Renseignés une seule fois, à l'activation — jamais modifiés ensuite.
  activatedByUserId   String?
  activatedByUser     User?     @relation("GatineBoxActivatedBy", fields: [activatedByUserId], references: [id])
  activatedAt         DateTime?
  creditTransactionId String?

  @@index([status])
}
